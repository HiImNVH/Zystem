# .gitignore
# CHIEN LUOC: chan TOAN BO moi thu o root, chi mo khoa backend/ va frontend/
# => moi file/thu muc moi phat sinh sau nay o root (vd: outputs/, ghi chu ca nhan...)
# se TU DONG bi bo qua, khong can sua file nay them.

# Mac dinh bo qua tat ca o cap root
/*

# Chi cho phep 2 thu muc nay duoc day len Git
!/backend/
!/frontend/
!/.gitignore

# ----------------------------------------------------------------------------
# Cac rule ben duoi ap dung o MOI CAP, ke ca ben trong backend/ va frontend/
# ----------------------------------------------------------------------------

# Thu muc cai dat thu vien (Bat buoc phai bo qua vi qua nang)
node_modules/
jspm_packages/

# Tep tin cau hinh bao mat (Chua mat khau database, tuyet doi khong len Git)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Log files cua he thong
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Thu muc build/output (Neu sau nay ban dung TypeScript hoac build React)
dist/
build/

# Cac file rac cua he dieu hanh Windows/Mac
Thumbs.db
.DS_Store