# backend/.env.example
# Version: 2.0
# Cap nhat: Bo sung PASSWORD_SALT va LOG_LEVEL

# ------------------------------------------------------------------------------
# CAU HINH CO SO DU LIEU (POSTGRESQL TRONG DOCKER)
# Tuong duong voi container game_db cua du an Zystem
# ------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=game_admin
DB_PASSWORD=your_password_here
DB_NAME=game_mmorpg

# ------------------------------------------------------------------------------
# CAU HINH SERVER NODE.JS
# ------------------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# Salt dung de hash mat khau — thay bang gia tri ngau nhien an toan khi production
PASSWORD_SALT=zystem_salt_change_me_in_production

# Muc do log: error | warn | info | debug
LOG_LEVEL=info

# JWT Configuration
JWT_SECRET=zystem_jwt_super_secret_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
