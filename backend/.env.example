# backend/.env.example

# ---------------------------------------------------------------------------
# Production example: Render + Neon
# ---------------------------------------------------------------------------
# Use Neon's pooled connection string when deploying to Render.
# Do not commit real secrets. Put real values in Render Environment Variables.
DATABASE_URL=postgresql://neondb_owner:<PASSWORD>@ep-plain-tree-ao0qzzqr-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DB_SSL=true

# Render provides PORT automatically. Keep this for local fallback only.
PORT=5000
NODE_ENV=production
LOG_LEVEL=info

# Add your deployed frontend URL after Vercel/Cloudflare Pages is ready.
# Example: CORS_ORIGIN=https://zystem-alpha.vercel.app
CORS_ORIGIN=

# Keep false for public alpha. Setting true wipes all tables on backend start.
RESET_DATABASE_ON_START=false

# Replace with a long random string, at least 32 characters.
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ---------------------------------------------------------------------------
# Local development alternative: PostgreSQL on localhost
# ---------------------------------------------------------------------------
# Leave DATABASE_URL empty and use these values locally if needed.
# DATABASE_URL=
# DB_SSL=false
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=zystem_admin
# DB_PASSWORD=zystem_password_postgres_NVH_SNK
# DB_NAME=zystem_db
