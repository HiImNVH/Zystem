# backend/.env.example

# PostgreSQL
# For local Docker, use localhost.
# For Neon/hosted Postgres, use the values from the provider dashboard.
DB_HOST=localhost
DB_PORT=5432
DB_USER=zystem_admin
DB_PASSWORD=change_me
DB_NAME=zystem_db

# Server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Auth
JWT_SECRET=zystem_jwt_super_secret_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
