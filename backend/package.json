{
  "name": "zystem-backend",
  "version": "1.0.0",
  "description": "Zystem MMORPG Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:full": "docker start zystem-postgres && sleep 2 && nodemon src/index.js",
    "db:start": "docker start zystem-postgres",
    "db:stop": "docker stop zystem-postgres",
    "db:status": "docker ps --filter name=zystem-postgres"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
